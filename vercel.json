{
  "version": 2,
  "functions": {
    "api/**/*.js": { "maxDuration": 30 }
  },
  "rewrites": [
    { "source": "/login", "destination": "/public/login.html" },
    { "source": "/child-login", "destination": "/public/child-login.html" },
    { "source": "/app", "destination": "/public/app.html" },
    { "source": "/dashboard", "destination": "/public/dashboard.html" },
    { "source": "/privacy", "destination": "/public/privacy.html" },
    { "source": "/terms", "destination": "/public/terms.html" },
    { "source": "/refund", "destination": "/public/refund.html" },
    { "source": "/gdpr", "destination": "/public/gdpr.html" },
    { "source": "/(.*)", "destination": "/public/$1" }
  ],
  "headers": [
    {
      "source": "/sw.js",
      "headers": [
        { "key": "Service-Worker-Allowed", "value": "/" },
        { "key": "Cache-Control", "value": "no-cache" }
      ]
    }
  ]
}
