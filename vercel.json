{
    "version": 2,
    "functions": {
        "api/**/*.js": { "maxDuration": 30 }
    },
    "rewrites": [
        { "source": "/login", "destination": "/login.html" },
        { "source": "/child-login", "destination": "/child-login.html" },
        { "source": "/app", "destination": "/app.html" },
        { "source": "/dashboard", "destination": "/dashboard.html" },
        { "source": "/pricing", "destination": "/pricing.html" },
        { "source": "/verify-email", "destination": "/verify-email.html" },
        { "source": "/privacy", "destination": "/privacy.html" },
        { "source": "/terms", "destination": "/terms.html" },
        { "source": "/refund", "destination": "/refund.html" },
        { "source": "/gdpr", "destination": "/gdpr.html" }
    ],
    "headers": [
        {
            "source": "/sw.js",
            "headers": [
                { "key": "Service-Worker-Allowed", "value": "/" },
                { "key": "Cache-Control", "value": "no-cache" }
            ]
        },
        {
            "source": "/(.*)",
            "headers": [
                {
                    "key": "Content-Security-Policy",
                    "value": "default-src 'self'; script-src 'self' 'unsafe-inline' https://cdn.jsdelivr.net https://unpkg.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: blob: https:; connect-src 'self' https://*.supabase.co wss://*.supabase.co https://api.lemonsqueezy.com; frame-src 'self' https://*.lemonsqueezy.com; base-uri 'self'; form-action 'self'"
                },
                {
                    "key": "X-Content-Type-Options",
                    "value": "nosniff"
                },
                {
                    "key": "X-Frame-Options",
                    "value": "DENY"
                },
                {
                    "key": "Referrer-Policy",
                    "value": "strict-origin-when-cross-origin"
                },
                {
                    "key": "Permissions-Policy",
                    "value": "camera=(), microphone=(), geolocation=()"
                }
            ]
        }
    ]
}
