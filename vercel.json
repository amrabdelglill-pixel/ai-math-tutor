{
  "version": 2,
  "builds": [
    { "src": "api/**/*.js", "use": "@vercel/node" },
    { "src": "public/**", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/$1" },
    { "src": "/(.*\\.(css|js|png|svg|ico|webp))", "dest": "/public/$1" },
    { "src": "/login", "dest": "/public/login.html" },
    { "src": "/app", "dest": "/public/app.html" },
    { "src": "/dashboard", "dest": "/public/dashboard.html" },
    { "src": "/", "dest": "/public/index.html" }
  ],
  "functions": {
    "api/**/*.js": {
      "memory": 256,
      "maxDuration": 30
    }
  }
}
