      {
        "start": 0.0,
        "duration": 11.0,
        "text": "Hi, friends. It's me, Baby Taku. Guess what? Today we're going on a super fun adventure to the farm."
      },
      {
        "start": 11.0,
        "duration": 11.0,
        "text": "Are you ready to come with me? I bet you are. We're going to meet all the animals and all need your help along the way."
      },
      {
        "start": 22.0,
        "duration": 5.0,
        "text": "Are you ready to join me? Let's go!"
      },
      {
        "start": 27.0,
