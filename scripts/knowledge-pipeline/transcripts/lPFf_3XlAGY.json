      },
      {
        "start": 44.0,
        "duration": 6.0,
        "text": "Wow! Mr. Cow is big and gentle."
      },
      {
        "start": 50.0,
        "duration": 6.0,
        "text": "He's got black and white spots and he loves to say, MMMMMMMMM."
      },
      {
        "start": 56.0,
        "duration": 6.0,
        "text": "Can you move with me? Come on. Let's all do it together."
      },
      {
        "start": 62.0,
